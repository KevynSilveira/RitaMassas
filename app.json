{
  "expo": {
    "name": "RitaMassas",
    "slug": "RitaMassas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/chef-hat-icon.png",
    "scheme": "ritamassas",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/chef-hat-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F3EF"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/chef-hat-adaptive.png",
        "backgroundColor": "#F7F3EF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/chef-hat-favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app usa fotos para ilustrar as massas no cadastro."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
